{
  "@context": {
    "@version": 1.1,
    "@vocab": "https://developers.google.com/sheets/api/reference/rest/v4/spreadsheets#",
    "schema": "https://schema.org/",
    "sheets": "https://developers.google.com/sheets/api/reference/rest/v4/spreadsheets#",
    "goog": "https://developers.google.com/sheets/api/reference/rest/v4/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "Spreadsheet": {
      "@id": "sheets:Spreadsheet",
      "@context": {
        "spreadsheetId": {
          "@id": "sheets:Spreadsheet.spreadsheetId",
          "@type": "xsd:string"
        },
        "properties": {
          "@id": "sheets:Spreadsheet.properties",
          "@type": "@id"
        },
        "sheets": {
          "@id": "sheets:Spreadsheet.sheets",
          "@type": "@id",
          "@container": "@set"
        },
        "namedRanges": {
          "@id": "sheets:Spreadsheet.namedRanges",
          "@type": "@id",
          "@container": "@set"
        },
        "spreadsheetUrl": {
          "@id": "sheets:Spreadsheet.spreadsheetUrl",
          "@type": "schema:URL"
        },
        "developerMetadata": {
          "@id": "sheets:Spreadsheet.developerMetadata",
          "@type": "@id",
          "@container": "@set"
        },
        "dataSources": {
          "@id": "sheets:Spreadsheet.dataSources",
          "@type": "@id",
          "@container": "@set"
        },
        "dataSourceSchedules": {
          "@id": "sheets:Spreadsheet.dataSourceSchedules",
          "@type": "@id",
          "@container": "@set"
        }
      }
    },

    "SpreadsheetProperties": {
      "@id": "sheets:SpreadsheetProperties",
      "@context": {
        "title": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "locale": {
          "@id": "schema:inLanguage",
          "@type": "xsd:string"
        },
        "autoRecalc": {
          "@id": "sheets:SpreadsheetProperties.autoRecalc",
          "@type": "xsd:string"
        },
        "timeZone": {
          "@id": "sheets:SpreadsheetProperties.timeZone",
          "@type": "xsd:string"
        },
        "defaultFormat": {
          "@id": "sheets:SpreadsheetProperties.defaultFormat",
          "@type": "@id"
        },
        "iterativeCalculationSettings": {
          "@id": "sheets:SpreadsheetProperties.iterativeCalculationSettings",
          "@type": "@id"
        },
        "spreadsheetTheme": {
          "@id": "sheets:SpreadsheetProperties.spreadsheetTheme",
          "@type": "@id"
        },
        "importFunctionsExternalUrlAccessAllowed": {
          "@id": "sheets:SpreadsheetProperties.importFunctionsExternalUrlAccessAllowed",
          "@type": "xsd:boolean"
        }
      }
    },

    "Sheet": {
      "@id": "sheets:Sheet",
