          "@container": "@set"
        },
        "conditionalFormats": {
          "@id": "sheets:Sheet.conditionalFormats",
          "@type": "@id",
          "@container": "@set"
        },
        "filterViews": {
          "@id": "sheets:Sheet.filterViews",
          "@type": "@id",
          "@container": "@set"
        },
        "protectedRanges": {
          "@id": "sheets:Sheet.protectedRanges",
          "@type": "@id",
          "@container": "@set"
        },
        "basicFilter": {
          "@id": "sheets:Sheet.basicFilter",
          "@type": "@id"
        },
        "charts": {
          "@id": "sheets:Sheet.charts",
          "@type": "@id",
          "@container": "@set"
        },
        "bandedRanges": {
          "@id": "sheets:Sheet.bandedRanges",
          "@type": "@id",
          "@container": "@set"
        },
        "slicers": {
          "@id": "sheets:Sheet.slicers",
          "@type": "@id",
          "@container": "@set"
        }
