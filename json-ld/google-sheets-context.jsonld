    "SheetProperties": {
      "@id": "sheets:SheetProperties",
      "@context": {
        "sheetId": {
          "@id": "sheets:SheetProperties.sheetId",
          "@type": "xsd:integer"
        },
        "title": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "index": {
          "@id": "schema:position",
          "@type": "xsd:integer"
        },
        "sheetType": {
          "@id": "sheets:SheetProperties.sheetType",
          "@type": "xsd:string"
        },
        "gridProperties": {
          "@id": "sheets:SheetProperties.gridProperties",
          "@type": "@id"
        },
        "hidden": {
          "@id": "sheets:SheetProperties.hidden",
          "@type": "xsd:boolean"
        },
        "tabColor": {
